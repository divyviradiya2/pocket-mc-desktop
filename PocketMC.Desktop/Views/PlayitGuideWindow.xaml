<Window x:Class="PocketMC.Desktop.Views.PlayitGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playit.gg Setup Guide"
        Width="420" Height="340"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="🌐 Playit.gg Agent Setup"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#CDD6F4"
                   Margin="0,0,0,16"/>

        <!-- Instructions -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="A browser window has opened. Follow these steps:"
                       Foreground="#BAC2DE" FontSize="13"
                       Margin="0,0,0,12" TextWrapping="Wrap"/>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="1. "/>
                <Run Text="Log in to your Playit.gg account."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="2. "/>
                <Run Text="Enter a name for this agent (e.g., 'My PC')."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="3. "/>
                <Run Text="Click 'Create Agent'."/>
            </TextBlock>

            <TextBlock Foreground="#89B4FA" FontSize="12" Margin="8,10,8,0"
                       FontStyle="Italic" TextWrapping="Wrap"
                       Text="This window will close automatically when setup is complete. You can also close it manually if needed."/>
        </StackPanel>

        <!-- Status + Close button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="StatusText"
                       Text="Waiting for setup..."
                       Foreground="#F9E2AF" FontSize="11"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>

            <Button x:Name="CloseButton"
                    Content="Cancel"
                    Width="80" Height="30"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
