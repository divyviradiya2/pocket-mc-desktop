<Window x:Class="PocketMC.Desktop.Views.TunnelLimitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tunnel Limit Reached"
        Width="520" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="⚠ Tunnel Limit Reached (4/4)"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#F38BA8"
                   Margin="0,0,0,12"/>

        <!-- Explanation -->
        <TextBlock Grid.Row="1"
                   Foreground="#BAC2DE" FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"
                   Text="Your Playit.gg account has reached the maximum of 4 tunnels. To make this server public, either delete a tunnel from your Playit.gg dashboard, or change this server's port to one that already has a tunnel assigned."/>

        <!-- Existing tunnels list -->
        <Border Grid.Row="2" Background="#313244" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Current Tunnels:"
                           Foreground="#CDD6F4" FontWeight="Bold" FontSize="13"
                           Margin="0,0,0,8"/>
                <ItemsControl x:Name="TunnelListControl" Foreground="#A6ADC8" FontSize="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Port, StringFormat='Port {0}'}"
                                           Foreground="#F9E2AF" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding PublicAddress}"
                                           Foreground="#89B4FA"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OpenDashboardButton"
                    Content="Open Tunnel Dashboard"
                    Width="180" Height="32"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Margin="0,0,12,0"
                    Click="OpenDashboardButton_Click"/>

            <Button x:Name="ChangePortButton"
                    Content="Change Port"
                    Width="120" Height="32"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0"
                    Click="ChangePortButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
