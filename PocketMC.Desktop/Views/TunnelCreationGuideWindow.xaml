<Window x:Class="PocketMC.Desktop.Views.TunnelCreationGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Tunnel"
        Width="420" Height="360"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="🔗 Create a Tunnel"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#CDD6F4"
                   Margin="0,0,0,16"/>

        <!-- Instructions -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="A browser window has opened. Follow these steps:"
                       Foreground="#BAC2DE" FontSize="13"
                       Margin="0,0,0,12" TextWrapping="Wrap"/>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="1. "/>
                <Run Text="Click 'Create Tunnel'."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="2. "/>
                <Run Text="Enter a tunnel name."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="3. "/>
                <Run Text="Select tunnel type: Minecraft Java."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="4. "/>
                <Run Text="Select 'Free Network'."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4" x:Name="PortInstructionText">
                <Run FontWeight="Bold" Text="5. "/>
                <Run Text="Enter port: "/>
                <Run FontWeight="Bold" Foreground="#F9E2AF" x:Name="PortValueRun" Text="25565"/>
                <Run Text=" (your server's configured port)."/>
            </TextBlock>

            <TextBlock Foreground="#A6E3A1" FontSize="13" Margin="8,4">
                <Run FontWeight="Bold" Text="6. "/>
                <Run Text="Click 'Create'."/>
            </TextBlock>

            <TextBlock Foreground="#89B4FA" FontSize="12" Margin="8,12,8,0"
                       FontStyle="Italic" TextWrapping="Wrap"
                       Text="This window will close automatically when the tunnel is detected."/>
        </StackPanel>

        <!-- Status -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="StatusText"
                       Text="Polling for new tunnel..."
                       Foreground="#F9E2AF" FontSize="11"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>

            <Button Content="Cancel"
                    Width="80" Height="30"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
