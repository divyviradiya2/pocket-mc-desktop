<Page x:Class="PocketMC.Desktop.Features.Console.ServerConsolePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Server Console"
      PreviewKeyDown="Page_PreviewKeyDown">
    
    <Grid x:Name="PageRoot" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top bar: Console actions -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" Content="Back" Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowLeft24}" Click="BtnBack_Click" Cursor="Hand" Margin="0,0,12,0"/>

            <ToggleButton x:Name="BtnAutoScroll" Grid.Column="1" Content="Auto-scroll"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Cursor="Hand" Padding="12,5"/>

            <ui:Button Grid.Column="2" Content="Copy Logs" Appearance="Secondary"
                       Icon="{ui:SymbolIcon Copy24}" Click="BtnCopyLogs_Click" Cursor="Hand" Margin="0,0,8,0"/>

            <ui:TextBox x:Name="TxtLogSearch" Grid.Column="3" PlaceholderText="Search logs..."
                        Margin="0,0,8,0" MinWidth="160" VerticalAlignment="Center"
                        TextChanged="TxtLogSearch_TextChanged"/>

            <ComboBox x:Name="CmbLogFilter" Grid.Column="4" Margin="0,0,8,0" SelectedIndex="0" VerticalAlignment="Center" Width="140" SelectionChanged="CmbLogFilter_SelectionChanged">
                <ComboBoxItem Content="All Logs"/>
                <ComboBoxItem Content="Info +"/>
                <ComboBoxItem Content="Warnings/Errors"/>
                <ComboBoxItem Content="Crashes/Exceptions"/>
            </ComboBox>

            <ui:Button Grid.Column="5" Content="Stop Server" Appearance="Danger"
                       Icon="{ui:SymbolIcon Stop24}" Click="BtnStop_Click" Cursor="Hand" Margin="0,0,8,0"
                       IsEnabled="{Binding CanStopServer}"/>

            <ui:Button Grid.Column="6" Content="Restart" Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowSync24}" Click="BtnRestart_Click" Cursor="Hand"/>
        </Grid>
        
        <!-- Console output area -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" x:Name="CrashBanner" Background="#33FF0000" BorderBrush="#88FF0000" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="Warning24" Margin="0,0,8,0" Foreground="#FF6B6B"/>
                            <ui:TextBlock FontTypography="Subtitle" Text="Critical Crash Detected!" Foreground="#FF6B6B" VerticalAlignment="Center"/>
                            <ui:Button Content="Copy Crash Report" Appearance="Secondary" Icon="{ui:SymbolIcon Copy24}" Margin="16,0,0,0" Padding="8,4" Click="BtnCopyCrash_Click"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" x:Name="TxtCrashLog" Foreground="#FF6B6B" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.9"/>
                    </Grid>
                </Border>

                <!-- Virtualized Log View -->
                <ListView x:Name="LogView" Grid.Row="1" ItemsSource="{Binding FilteredLogs}" 
                            Background="Transparent" BorderThickness="0"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling"
                            PreviewMouseWheel="LogView_PreviewMouseWheel">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Foreground="{Binding TextColor}" 
                                        FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                                        Padding="4,1"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
        
        <!-- Command input bar -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ui:AutoSuggestBox x:Name="TxtCommand" Grid.Column="0" PlaceholderText="Type a command..." 
                               Margin="0,0,8,0" 
                               TextChanged="TxtCommand_TextChanged"
                               SuggestionChosen="TxtCommand_SuggestionChosen"
                               QuerySubmitted="TxtCommand_QuerySubmitted"
                               KeyDown="TxtCommand_KeyDown"
                               OriginalItemsSource="{Binding CommandSuggestions}"/>
            <ui:Button Grid.Column="1" Content="Send" Appearance="Primary"
                       Icon="{ui:SymbolIcon Send24}" Click="BtnSend_Click" Cursor="Hand"/>
        </Grid>
    </Grid>
</Page>
